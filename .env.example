# ============================================================
# .env.example — SMB Intelligence Platform
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Google Cloud ---
GCP_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=smb-intelligence-bucket
GCS_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json
BIGQUERY_DATASET=smb_intelligence
BIGQUERY_LOCATION=asia-south1

# --- API ---
API_PORT=8000
MOCK_MODE=false

# --- GitHub ---
GITHUB_TOKEN=your-github-token
GITHUB_REPO=adarsh-gautam-sys/smb-intel-rapids

# --- Data Generation ---
DATA_START_DATE=2023-01-01
DATA_END_DATE=2024-12-31
NUM_SKUS=50
STORE_ID=STORE_MUMBAI_001
